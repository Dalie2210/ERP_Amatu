# ============================================================
# Amatu ERP — Variables de entorno requeridas
# ============================================================
# Copia este archivo como .env.development.local (dev) o
# configura las variables directamente en Vercel (producción).
# NUNCA commitees archivos .env con valores reales.
# ============================================================

# Supabase — obtener en: dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kapso (mensajería)
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_API_KEY=your-kapso-api-key
KAPSO_WORKFLOW_RUTA_ID=your-workflow-id
